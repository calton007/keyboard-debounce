# Normalize text files in the repository
* text=auto

# Keep source and docs as LF in repo
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=crlf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.ico binary
*.exe binary
*.zip binary
*.msi binary